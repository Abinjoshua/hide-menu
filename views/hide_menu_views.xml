<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--    create form view    -->
    <record id="hide_menu_views_form" model="ir.ui.view">
        <field name="name">hide.menus.views.form</field>
        <field name="model">hide.menus</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <!--    create list view    -->
    <record id="recurring_subscription_views_list" model="ir.ui.view">
        <field name="name">hide.menus.views.list</field>
        <field name="model">hide.menus</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
            </list>
        </field>
    </record>
    <!--    Window action sub-->
    <record id="action_hide_menus" model="ir.actions.act_window">
        <field name="name">Hide Menu</field>
        <field name="res_model">hide.menus</field>
        <field name="view_mode">list,form,kanban</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create your first Menu</p>
        </field>
    </record>
</odoo>